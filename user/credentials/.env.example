# Claudia OS — variables de entorno
# Copia este fichero a .env y rellena los valores que necesites.
# Solo tienes que configurar las skills que vayas a usar.
# Las skills marcadas con (sin config) funcionan sin ninguna variable.

# ─────────────────────────────────────────
# TELEGRAM — skill: telegram-bot
# Obtén el token en @BotFather y tu ID en @userinfobot
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# ─────────────────────────────────────────
# GOOGLE AI STUDIO — skill: claudia-image
# API key en https://aistudio.google.com/apikey
# Modelo flash (1:1) = gratis. Resto de modelos tienen coste ($0.02-$0.06/img).
# Recomendamos poner un límite de gasto en Settings > Billing de AI Studio.
# ─────────────────────────────────────────
GOOGLE_AI_API_KEY=

# ─────────────────────────────────────────
# OPENAI — skill: claudia-image (modelos openai, openai-hd)
# API key en https://platform.openai.com/api-keys
# GPT Image 2: ~$0.05/img (medium), ~$0.21/img (high)
# Recomendamos poner un límite en https://platform.openai.com/settings/organization/limits
# ─────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────
# GOOGLE CALENDAR — skill: claudia-calendar
# URL del Apps Script desplegado (ver README de claudia-calendar)
# ─────────────────────────────────────────
CALENDAR_WEBAPP_URL=

# ─────────────────────────────────────────
# EMAIL — skill: claudia-intake (briefing diario)
# Remitente y destinatario del briefing por email
# ─────────────────────────────────────────
EMAIL_FROM=
EMAIL_TO=

# Servidor SMTP — solo si no tienes OAuth de Gmail configurado.
# Si ya autorizaste claudia-gmail, el sistema usa ese token y esto no hace falta.
# Si usas Gmail como SMTP: host smtp.gmail.com, puerto 587, App Password (no tu contraseña normal).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─────────────────────────────────────────
# CLAUDE CODE — autenticación para crons
# Token OAuth de larga duración (1 año) generado con `claude setup-token`.
# Necesario porque los crons no heredan la sesión interactiva de Claude.
# Sin esto, cualquier cron que ejecute `claude -p` fallará con "Not logged in".
# ─────────────────────────────────────────
CLAUDE_CODE_OAUTH_TOKEN=
